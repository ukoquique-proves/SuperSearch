# SuperSearch — environment configuration template
# Copy this file to .env and fill in the values you want.
# All keys are optional; the free providers work without any key.

# --- Optional API keys (more providers = broader coverage) ---

# Brave Search: https://api.search.brave.com/
BRAVE_API_KEY=

# Google Custom Search Engine
# Create a CSE: https://programmablesearchengine.google.com/
# Enable API + get key: https://console.cloud.google.com/
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_CX=

# Bing Web Search: https://portal.azure.com/
BING_API_KEY=

# Mojeek (free tier): https://www.mojeek.com/services/search/api
MOJEEK_API_KEY=

# Semantic Scholar (free, no credit card): https://www.semanticscholar.org/product/api
# Avoids the 429 rate-limit that affects unauthenticated requests.
SEMANTIC_SCHOLAR_API_KEY=

# --- SearX instances ---
# Comma-separated list of SearX/SearXNG instances to query in parallel.
# Defaults to a built-in pool of 17 public instances when this variable is unset.
# SEARX_INSTANCES=https://searx.tiekoetter.com,https://search.mdosch.de

# --- Tuning ---
# Per-provider HTTP request timeout in seconds (default: 15)
# SEARCH_TIMEOUT=15
