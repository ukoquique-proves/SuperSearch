# Optional API keys — more providers = broader coverage
BRAVE_API_KEY=
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_CX=
BING_API_KEY=
MOJEEK_API_KEY=

# Free API key from https://www.semanticscholar.org/product/api — no credit card needed
SEMANTIC_SCHOLAR_API_KEY=

# Comma-separated SearX instances (meta-search aggregates many engines)
SEARX_INSTANCES=https://searx.tiekoetter.com,https://search.mdosch.de,https://opnxng.com,https://searx.be,https://priv.au,https://searxng.site,https://baresearch.org,https://search.ononoki.org,https://searx.ru,https://gruble.de,https://searx.ch,https://search.bus-hit.me,https://search.inetol.net

# Request timeout in seconds (default: 15)
SEARCH_TIMEOUT=15
